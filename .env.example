# ─────────────────────────────────────────────────────────────────────────────
# .env.example — S.T.A.R.L.I.N.G. environment variables
#
# Copy this file to .env and edit the values for your setup.
#   cp .env.example .env
#
# Variables marked (required) must be set for the relevant backend to work.
# Variables marked (optional) have sensible defaults and can be left as-is.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM backend selection ─────────────────────────────────────────────────────
# Controls which LLM relay is loaded at startup. Both expose /chat/ with the
# same NDJSON streaming format — no frontend changes are needed when switching.
#
# "llama"  → backend/llama_server.py — talks directly to llama-server (llama.cpp)
#            Faster first-token latency; recommended for local GPU setups.
#            Requires: scripts/start_llama_server.bat to be running.
# "ollama" → backend/ollama.py — talks to Ollama's /api/chat endpoint.
#            Easier setup; Ollama manages the model process automatically.
#
LLM_BACKEND=llama


# ── llama-server / llama.cpp ──────────────────────────────────────────────────
# Used when LLM_BACKEND=llama.
#
# To start llama-server:
#   Windows:  scripts\start_llama_server.bat
#   Linux:    llama-server --model <path> --alias <name> --n-gpu-layers 999 --ctx-size 4096 --port 8080
#
# Download llama-server binaries:
#   https://github.com/ggml-org/llama.cpp/releases  (llama-*-win-cuda-cu12.x.x-x64.zip)
#
# (required) URL where llama-server is listening.
LLAMA_SERVER_URL=http://localhost:8080

# (required) Model alias — must match the --alias flag passed to llama-server.
LLAMA_MODEL=llama3.2-3b

# (optional) Sampling temperature. 0.0 = deterministic, 1.0 = creative.
LLAMA_TEMPERATURE=0.7

# (optional) System prompt injected at the start of every conversation.
LLAMA_SYSTEM_PROMPT=You are S.T.A.R.L.I.N.G. (Speech‑Triggered Autonomous Reasoning & Local Intelligence Node Generator), a highly capable local AI assistant. Be concise, precise, and direct. Avoid unnecessary pleasantries.


# ── Ollama ────────────────────────────────────────────────────────────────────
# Used when LLM_BACKEND=ollama. Ollama must be running and have the model pulled.
#   Install: https://ollama.com
#   Pull:    ollama pull llama3.2:3b
#
# (required) Base URL for the Ollama HTTP API.
OLLAMA_BASE_URL=http://localhost:11434

# (required) Model tag as shown in `ollama list`.
OLLAMA_MODEL=llama3.2:3b

# (optional) Sampling temperature.
OLLAMA_TEMPERATURE=0.7

# (optional) System prompt.
OLLAMA_SYSTEM_PROMPT=You are S.T.A.R.L.I.N.G. (Speech‑Triggered Autonomous Reasoning & Local Intelligence Node Generator), a highly capable local AI assistant. Be concise, precise, and direct. Avoid unnecessary pleasantries.


# ── FastAPI backend ───────────────────────────────────────────────────────────
# (optional) Port the uvicorn server listens on.
BACKEND_PORT=8000

# (optional) CORS allowed origins. "*" permits all origins (fine for local dev).
# Tighten to e.g. "http://localhost:8000" in production.
CORS_ORIGINS=*


# ── STT — faster-whisper ──────────────────────────────────────────────────────
# (optional) Whisper model size. Larger = more accurate, slower, more VRAM.
#   tiny | base | small | medium | large-v3
#   Recommended for most GPUs: base (fast, good accuracy)
WHISPER_MODEL_SIZE=base

# (optional) Inference device for faster-whisper / ctranslate2.
#   cuda  — NVIDIA GPU (requires CUDA 12 runtime; auto-falls back to cpu if unavailable)
#   cpu   — CPU only; slower but works everywhere
WHISPER_DEVICE=cuda


# ── TTS — Kokoro ONNX ────────────────────────────────────────────────────────
# (optional) ONNX execution provider for Kokoro TTS.
# kokoro-onnx cannot auto-detect onnxruntime-gpu (package name contains a hyphen
# which is not a valid Python identifier), so the provider must be set explicitly.
#
#   CUDAExecutionProvider    — NVIDIA GPU via CUDA 12 + cuDNN 9
#                              Requires: onnxruntime-gpu, CUDA toolkit
#   DmlExecutionProvider     — GPU via DirectX 12 (Windows only, no CUDA toolkit needed)
#                              Requires: onnxruntime-directml
#   CPUExecutionProvider     — CPU fallback; works everywhere, noticeably slower
#
ONNX_PROVIDER=CUDAExecutionProvider


# ── Weather — Open-Meteo (Tool 3) ─────────────────────────────────────────────
# (required) Location name as passed to the Open-Meteo geocoding API.
WEATHER_LOCATION=Framingham,Massachusetts

# (optional) Temperature units: fahrenheit | celsius
WEATHER_UNITS=fahrenheit

# (optional) How long to cache weather responses in seconds (default 10 minutes).
WEATHER_CACHE_SECONDS=600


# ── News Briefing — RSS (Tool 4) ──────────────────────────────────────────────
# (optional) Comma-separated list of RSS feed URLs.
# Each feed contributes up to NEWS_PER_FEED headlines.
NEWS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://feeds.reuters.com/reuters/topNews,https://feeds.npr.org/1001/rss.xml

# (optional) Max headlines pulled from each individual feed.
NEWS_PER_FEED=5

# (optional) Max headlines injected into the LLM briefing context.
NEWS_LLM_LIMIT=10

# (optional) Cache duration in seconds (default 15 minutes).
NEWS_CACHE_SECONDS=900
