# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.7
OLLAMA_SYSTEM_PROMPT=You are JARVIS, a highly capable AI assistant created to serve. Be concise, precise, and direct. Avoid unnecessary pleasantries.

# Backend
BACKEND_PORT=8000

# STT (only needed if using faster-whisper)
# WHISPER_MODEL_SIZE=base

# TTS (only needed if using Kokoro)
# KOKORO_VOICE=af
